[Unit]
Description=CrabTrap LLM Reviewer
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/projects/crabtrap-lite
EnvironmentFile=/root/.config/crabtrap-llm-reviewer.env
ExecStart=/usr/bin/node /root/projects/crabtrap-lite/src/llm-reviewer.js
Restart=always
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
