ACTION_GATE_HOST=127.0.0.1
ACTION_GATE_PORT=8787
ACTION_GATE_RECEIPT_MODE=truthful
ACTION_GATE_MODE=soft_gate
ACTION_GATE_REVIEWER_URL=http://127.0.0.1:8791/review
ACTION_GATE_REVIEWER_FAIL_MODE=closed
ACTION_GATE_REVIEWER_TIMEOUT_MS=6000
CRABTRAP_CREDENTIALS_DIR=/root/.config/crabtrap-lite-adapters
# Optional: protect operator/UI endpoints with a token. When unset, loopback-only access is allowed.
ACTION_GATE_UI_TOKEN=
